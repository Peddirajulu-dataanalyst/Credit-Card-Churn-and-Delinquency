      <column caption='utilization_bucketc' datatype='string' name='[Calculation_0821110084333575]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [utilization_ratio] &lt;= 0.2 THEN &quot;Very Low&quot;&#13;&#10;ELSEIF [utilization_ratio] &lt;= 0.5 THEN &quot;Low&quot;&#13;&#10;ELSEIF [utilization_ratio] &lt;= 0.8 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot; END' />
