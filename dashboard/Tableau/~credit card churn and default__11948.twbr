      <column caption='utilization_bucket' datatype='string' name='[Calculation_0821110016585734]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [utilization_ratio (uci_credit.csv)] &lt;= 0.3 THEN &quot;Low&quot; ELSEIF [utilization_ratio (uci_credit.csv)] &lt;= 0.6 THEN &quot;Medium&quot; ELSE &quot;High&quot; END' />
