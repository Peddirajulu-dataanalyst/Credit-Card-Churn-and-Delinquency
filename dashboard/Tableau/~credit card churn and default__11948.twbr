      <column caption='Default Rate' datatype='real' name='[Calculation_0821109303562241]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([default_flag]) / COUNT([ID])' />
      </column>
      <column caption='High Utilization Rate' datatype='real' name='[Calculation_0821109303681026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([high_util_flag]) / COUNT([ID])' />
